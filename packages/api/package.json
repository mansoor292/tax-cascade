{
  "name": "@taxengine/api",
  "version": "0.1.0",
  "description": "IRS tax computation engine, PDF form filler, and MCP server",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "verify": "tsx scripts/verify_pipeline.ts",
    "fill:1040": "tsx src/builders/build_1040.ts",
    "fill:1120": "tsx src/builders/build_1120.ts",
    "fill:1120s": "tsx src/builders/build_1120s.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1033.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@supabase/supabase-js": "^2.103.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2"
  }
}
