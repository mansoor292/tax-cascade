{
  "name": "@taxengine/monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev -w packages/api",
    "api:start": "npm run start -w packages/api",
    "web:dev": "npm run dev -w packages/web",
    "web:build": "npm run build -w packages/web",
    "dev": "concurrently \"npm run api:dev\" \"npm run web:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
